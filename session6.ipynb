# Session 6 - ASTR 19 Code Journal

import math

def my_sin(x):
    return math.sin(x)

def my_cos(x):
    return math.cos(x)

def main():
    n = 1000
    start = 0
    end = 2 * math.pi
    step = (end - start) / n

    x = start

    # print first 10 values
    for i in range(10):
        print(x, my_sin(x), my_cos(x))
        x += step


if __name__ == "__main__":
    main()